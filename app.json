{
  "name": "QUEEN-KAVI-MD-MINI",
  "description": "Qᴜᴇᴇɴ Kᴀᴠɪ Mᴅ Mɪɴɪ — WhatsApp Multi-Session Bot by Savendra Dampriya",
  "logo": "https://i.ibb.co/SzsVXwp/1bf2ea0ee756.jpg",
  "repository": "https://github.com/savendra-dev/QUEEN-KAVI-MD-MINI",
  "keywords": ["Sʜᴀᴠɪʏᴀ-Tᴇᴄʜ", "whatsapp", "bot"],
  "success_url": "/",
  "buildpacks": [
    { "url": "https://github.com/heroku/heroku-buildpack-nodejs#latest" }
  ],
  "env": {
    "PORT": {
      "description": "Port for web server (5000 recommended)",
      "value": "5000",
      "required": false
    },
    "MONGO_URI": {
      "description": "MongoDB connection URI — mongodb+srv://user:pass@cluster.mongodb.net/",
      "value": "",
      "required": true
    },
    "MONGO_DB": {
      "description": "MongoDB database name",
      "value": "KAVI-MD",
      "required": false
    },
    "PREFIX": {
      "description": "Bot command prefix",
      "value": ".",
      "required": false
    },
    "BOT_NAME": {
      "description": "Bot display name",
      "value": "Qᴜᴇᴇɴ Kᴀᴠɪ Mᴅ Mɪɴɪ",
      "required": false
    },
    "OWNER_NAME": {
      "description": "Owner display name",
      "value": "Sᴀᴠᴇɴᴅʀᴀ Dᴀᴍᴘʀɪʏᴀ",
      "required": false
    },
    "OWNER_NUMBER": {
      "description": "Owner WhatsApp number (no + or spaces)",
      "value": "94707085822",
      "required": true
    },
    "BOT_FOOTER": {
      "description": "Footer text shown in messages",
      "value": "> ᴘᴏᴡᴇʀᴅ ʙʏ Qᴜᴇᴇɴ ᴋᴀᴠɪ ᴍɪɴɪ",
      "required": false
    },
    "IMAGE_PATH": {
      "description": "Bot image URL used in messages",
      "value": "https://i.ibb.co/SzsVXwp/1bf2ea0ee756.jpg",
      "required": false
    },
    "CHANNEL_LINK": {
      "description": "WhatsApp channel link",
      "value": "",
      "required": false
    },
    "GROUP_INVITE_LINK": {
      "description": "WhatsApp group invite link",
      "value": "",
      "required": false
    },
    "NEWSLETTER_JID": {
      "description": "Newsletter JID for auto-react",
      "value": "",
      "required": false
    },
    "NEWSLETTER_MESSAGE_ID": {
      "description": "Newsletter message ID",
      "value": "",
      "required": false
    },
    "AUTO_AI": {
      "description": "Auto AI reply — true / false",
      "value": "true",
      "required": false
    },
    "AUTO_VIEW_STATUS": {
      "description": "Auto view status — true / false",
      "value": "true",
      "required": false
    },
    "AUTO_LIKE_STATUS": {
      "description": "Auto like status — true / false",
      "value": "true",
      "required": false
    },
    "AUTO_RECORDING": {
      "description": "Auto recording presence — true / false",
      "value": "false",
      "required": false
    },
    "AUTO_TYPING": {
      "description": "Auto typing presence — true / false",
      "value": "false",
      "required": false
    },
    "AUTO_READ_MESSAGE": {
      "description": "Auto read messages — off / all / cmd",
      "value": "off",
      "required": false
    },
    "WORK_TYPE": {
      "description": "Bot work mode — public / private / inbox / groups",
      "value": "public",
      "required": false
    },
    "ANTI_CALL": {
      "description": "Auto reject calls — on / off",
      "value": "off",
      "required": false
    },
    "MAX_RETRIES": {
      "description": "Max retry attempts",
      "value": "3",
      "required": false
    },
    "BOT_VERSION": {
      "description": "Bot version string",
      "value": "1.0.0",
      "required": false
    },
    "OTP_EXPIRY": {
      "description": "OTP expiry in ms (300000 = 5 min)",
      "value": "300000",
      "required": false
    }
  }
}
